{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Transcript",
  "version": "1.0.0",
  "identifier": "com.bariskisir.transcript",
  "build": {
    "beforeDevCommand": "npm run watch --prefix frontend",
    "beforeBuildCommand": "npm run build --prefix frontend",
    "frontendDist": "frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Transcript",
        "width": 520,
        "height": 430,
        "minWidth": 430,
        "minHeight": 340,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
