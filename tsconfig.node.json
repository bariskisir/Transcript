{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "types": ["node", "vitest/globals"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "composite": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@main/*": ["./src/main/*"],
      "@shared/*": ["./src/shared/*"]
    }
  },
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "eslint.config.mjs",
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/renderer/src/i18n/locales/*.ts",
    "src/renderer/src/store/appSlice.ts",
    "src/renderer/src/services/SettingsPersistenceQueue.ts",
    "src/renderer/src/utils/formatters.ts",
    "src/shared/**/*.ts",
    "tests/**/*.ts"
  ]
}
